<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="AudioPlaybackConnector2.DevicePickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        MinWidth="260"
        MaxWidth="520">
        <SystemBackdropElement
            x:Name="BackdropElement"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CornerRadius="8" />
        <StackPanel x:Name="ContentPanel">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="TitleText"
                    Grid.Column="0"
                    Margin="5"
                    Padding="5"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis" />
                <Button
                    x:Name="CloseButton"
                    Grid.Column="1"
                    Margin="5"
                    Padding="5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0">
                    <FontIcon FontSize="15" Glyph="&#xE711;" />
                </Button>
            </Grid>
            <Grid
                x:Name="GlobalActionsPanel"
                Margin="5,0,5,0"
                Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="DisconnectAllButton"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Padding="8,4"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    BorderThickness="0">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <FontIcon
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Glyph="&#xE711;" />
                        <TextBlock
                            x:Name="DisconnectAllText"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ReconnectAllButton"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Padding="8,4"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <FontIcon
                            FontSize="12"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                            Glyph="&#xE72C;" />
                        <TextBlock
                            x:Name="ReconnectAllText"
                            FontSize="12"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                    </StackPanel>
                </Button>
            </Grid>
            <ProgressRing
                x:Name="ProgressIndicator"
                HorizontalAlignment="Center"
                IsActive="True" />
            <ListView
                x:Name="DeviceList"
                MaxHeight="480"
                Margin="5"
                SelectionMode="Single" />
        </StackPanel>
    </Grid>
</UserControl>
