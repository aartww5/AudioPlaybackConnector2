<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="AudioPlaybackConnector2.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AudioPlaybackConnector2"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Settings"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        Background="Transparent"
        Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <SystemBackdropElement
            x:Name="BackdropElement"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

        <Grid
            x:Name="TitleBarArea"
            Grid.Row="0"
            Height="32"
            Background="Transparent">
            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="AudioPlaybackConnector2" />
        </Grid>

        <ScrollViewer
            x:Name="SettingsContentHost"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Padding="10,8,10,8"
                HorizontalAlignment="Stretch"
                Spacing="12">

                <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="Settings" />
                    <TextBlock
                        x:Name="SubtitleText"
                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                        Text="Device connection and app behavior"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!-- Connection -->
                <Border
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel HorizontalAlignment="Stretch" Spacing="16">
                        <TextBlock
                            x:Name="ConnectionHeader"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Connection" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel MinWidth="0">
                                <TextBlock
                                    x:Name="AutoReconnectLabel"
                                    Text="Auto-reconnect on startup"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="AutoReconnectDesc"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Text="Automatically connects to the last used device."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="AutoReconnectToggle"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                MinWidth="64" />
                        </Grid>

                        <StackPanel x:Name="DevicesPanel" Spacing="8" />
                    </StackPanel>
                </Border>

                <!--  System  -->
                <Border
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel HorizontalAlignment="Stretch" Spacing="16">
                        <TextBlock
                            x:Name="SystemHeader"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="System" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel MinWidth="0">
                                <TextBlock
                                    x:Name="StartWithWindowsLabel"
                                    Text="Start with Windows"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="StartWithWindowsDesc"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Text="Starts the tray app automatically after sign-in."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="StartWithWindowsToggle"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                MinWidth="64" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel MinWidth="0">
                                <TextBlock
                                    x:Name="ShowNotificationsLabel"
                                    Text="Show notifications"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="ShowNotificationsDesc"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Text="Show toast notifications for connection events."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="ShowNotificationsToggle"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                MinWidth="64" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  App  -->
                <Border
                    Padding="18"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel HorizontalAlignment="Stretch" Spacing="12">
                        <TextBlock
                            x:Name="AppHeader"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="App" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel MinWidth="0">
                                <TextBlock
                                    x:Name="VersionText"
                                    Text="Version"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="CopyrightText"
                                    Margin="0,6,0,0"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Text="Copyright (C) 2026 Noah Meyer"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="CheckForUpdatesLabel"
                                    Margin="0,14,0,0"
                                    Text="Check for updates"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    x:Name="CheckForUpdatesDesc"
                                    FontSize="12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    Text="Looks for the latest GitHub release."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <ProgressRing
                                    x:Name="UpdateCheckProgress"
                                    Width="20"
                                    Height="20"
                                    IsActive="False"
                                    Visibility="Collapsed" />
                                <Button
                                    x:Name="CheckForUpdatesButton"
                                    Click="CheckForUpdatesButton_Click"
                                    Content="Check" />
                            </StackPanel>
                        </Grid>

                        <InfoBar
                            x:Name="UpdateInfoBar"
                            HorizontalAlignment="Stretch"
                            IsClosable="True"
                            IsOpen="False">
                            <InfoBar.ActionButton>
                                <Button
                                    x:Name="OpenAppInstallerButton"
                                    Click="OpenAppInstallerButton_Click"
                                    Content="Open installer"
                                    Visibility="Collapsed" />
                            </InfoBar.ActionButton>
                        </InfoBar>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
